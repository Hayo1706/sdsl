block Forms {
  name = column "Form": string;
  questions* = block Question;
}

block Question {
  test = column "test": boolean;
  name = column "Name": boolean;
  question = column "Question": boolean;
  type = column "Type": boolean;
  value ?= column "Value": boolean;
  condition ?= column "Condition": boolean;
  test2 = column "test2": boolean;
  test3 = column "test3": boolean;
}